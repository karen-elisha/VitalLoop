# ============================================
# VitalLoop — Environment Variables Template
# Copy to .env in each service directory
# ============================================

# --- Backend ---
NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vitalloop
REDIS_URL=redis://localhost:6379
JWT_SECRET=your-jwt-secret-change-me
JWT_REFRESH_SECRET=your-refresh-secret-change-me
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
AI_SERVICE_URL=http://localhost:8000
ENCRYPTION_KEY=your-aes-256-key-change-me
CORS_ORIGIN=http://localhost:5173

# --- Frontend ---
VITE_API_URL=http://localhost:3001/api
VITE_WS_URL=http://localhost:3001
VITE_APP_NAME=VitalLoop

# --- AI Service ---
AI_SERVICE_PORT=8000
AI_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vitalloop
ANTHROPIC_API_KEY=your-anthropic-api-key
AI_MODEL=claude-sonnet-4-20250514
